{
	"properties": {
		"_class": {
			"type": "text",
			"fields": {
				"keyword": {
					"type": "keyword",
					"ignore_above": 256
				}
			}
		},
		"authors": {
			"type": "text",
			"fields": {
				"keyword": {
					"type": "keyword",
					"ignore_above": 256
				}
			}
		},
		"description": {
			"type": "text",
			"copy_to": [
				"highlight"
			]
		},
		"fnExternalStoryID": {
			"type": "text",
			"fields": {
				"keyword": {
					"type": "keyword",
					"ignore_above": 256
				}
			}
		},
		"heroImage": {
			"type": "text",
			"fields": {
				"keyword": {
					"type": "keyword",
					"ignore_above": 256
				}
			}
		},
		"highlight": {
			"type": "text",
			"store": true,
			"analyzer": "body_analyzer",
			"search_analyzer": "body_search_analyzer",
			"fields": {
				"shingle": {
					"type": "text",
					"analyzer": "body_shingle_analyzer"
				},
				"simple": {
					"type": "text",
					"analyzer": "simple_analyzer",
					"store" : true
				}
			}
		},
		"indexText": {
			"type": "text",
			"copy_to": [
				"highlight"
			]
		},
		"publishedDate": {
			"type": "date"
		},
		"searchable_vector": {
			"type": "knn_vector",
			"dimension": 100
		},
		"subType": {
			"type": "text",
			"fields": {
				"keyword": {
					"type": "keyword",
					"ignore_above": 256
				}
			}
		},
		"title": {
			"type": "text",
			"fields": {
				"shingle": {
					"type": "text",
					"analyzer": "title_shingle_analyzer"
				},
				"simple": {
					"type": "text",
					"analyzer": "simple_analyzer"
				},
				"keyword": {
					"type": "keyword",
					"ignore_above": 256
				}
			},
			"analyzer": "title_analyzer",
			"search_analyzer": "title_search_analyzer"
		},
		"title_vector": {
			"type": "knn_vector",
			"dimension": 100
		}
	}
}